# CSFloat — csfloat.com → perfil → pestaña Developer (para generar la key
# CSFloat exige haber hecho al menos una compra o venta en su plataforma).
# La API pública puede responder sin clave, pero con límites estrictos;
# sin conexión a CSFloat la app cae a MODO DEMO con datos mock.
CSFLOAT_API_KEY=

# Steam se consulta en modo read-only con endpoints públicos (priceoverview).
# No requiere clave. Si Steam limita, la app usa caché o datos demo.

# Recolector (scripts/collector.mjs): CSFloat bloquea las IPs de Vercel,
# así que un PC con conexión residencial sube los datos al sitio.
# INGEST_SECRET debe ser el mismo aquí y en las variables de Vercel.
# En Vercel además debe existir un Blob store (BLOB_READ_WRITE_TOKEN).
INGEST_SECRET=
SITE_URL=

# Opcional: Supabase/Postgres para guardar historial de snapshots.
# Sin esto, el historial vive solo en memoria/mock.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Moneda por defecto para el simulador (tipo de cambio USD->CLP editable en la UI)
NEXT_PUBLIC_DEFAULT_USD_CLP=940
